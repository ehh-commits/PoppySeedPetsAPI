# Local docker-compose overrides. Copy to ".env" (which is gitignored) and uncomment
# anything you need to change for your machine.
#
# Defaults are the typical port for each service — you only need a .env file if
# something on your machine already owns one of these ports.

# Host port for MySQL. Default 3306.
# Override if you already have MySQL or MariaDB installed natively.
#DB_PORT=3307

# Host port for the Angular dev server. Default 4200.
# Override if another dev server is already on 4200.
#WEBAPP_PORT=4201

# Note: the API port (8000) is currently NOT overridable here, because
# webapp/src/environments/environment.ts hardcodes https://localhost:8000.
# Changing it would require threading the value through the Angular build.
